{
  "name": "vasanthaprakash",
  "version": "1.0.0",
  "description": "Data Analyst Portfolio - Vasanthaprakash E | SQL, Power BI, Python Expert",
  "main": "dist/bundle.js",
  "homepage": "https://vasanthaprakashe.github.io/vasanthaprakash",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --watch",
    "clean": "rm -rf dist",
    "copy-content": "cp -r src/content dist/ && cp -r admin dist/ 2>/dev/null || true",
    "copy-public": "cp -r public dist/ 2>/dev/null || true",
    "prebuild": "npm run clean && npm run copy-content && npm run copy-public",
    "preview": "npx serve dist",
    "deploy": "npm run build && echo '✅ Build complete! Push to GitHub to deploy'",
    "add-project": "node scripts/add-project.js",
    "add-blog": "node scripts/add-blog.js",
    "list-projects": "node scripts/add-project.js list",
    "list-blogs": "node scripts/add-blog.js list",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "analyze": "webpack --mode production --profile --json > stats.json"
  },
  "keywords": [
    "portfolio",
    "data-analyst",
    "github-pages",
    "typescript",
    "sql",
    "powerbi",
    "python",
    "data-visualization"
  ],
  "author": "Vasanthaprakash E",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VasanthaprakashE/vasanthaprakash"
  },
  "bugs": {
    "url": "https://github.com/VasanthaprakashE/vasanthaprakash/issues"
  },
  "homepage": "https://github.com/VasanthaprakashE/vasanthaprakash#readme",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "css-loader": "^6.8.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.54.0",
    "html-webpack-plugin": "^5.5.3",
    "prettier": "^3.1.0",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "crypto-js": "^4.2.0"
  }
}